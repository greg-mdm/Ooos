-.ood-prod-col:first-child{flex:0 0 auto;}
-.ood-prod-col:last-child{flex:1 1 auto;}
-.ood-prod-col + .ood-prod-col{position:relative;padding-left:16px;}
-.ood-prod-col + .ood-prod-col::before{content:'';position:absolute;left:0;top:3px;bottom:3px;width:3.5px;background:var(--dc,#bbb);clip-path:polygon(50% 0%,50% 0%,100% 100%,0% 100%);}
-.ood-col--mic .ood-prod-col + .ood-prod-col::before{--dc:#EFB609;}
-.ood-col--cid .ood-prod-col + .ood-prod-col::before{--dc:#DA4527;}
-.ood-col--ra .ood-prod-col + .ood-prod-col::before{--dc:#12A89C;}
-.ood-prod-h{margin:0 0 8px;font-family:Poppins,sans-serif;font-weight:600;font-size:.7rem;color:#0F031C;white-space:nowrap;}
-.ood-pills{display:flex;flex-direction:column;align-items:flex-start;gap:5px;}
+/* Two carved silver "dice" replace the old white products/services key.
+   Each die = a metallic rim + a recessed face that holds its own pills, so
+   products (Sunshine) and services (Indigo) can never cross over.
+
+   ART: both dice reuse ONE transparent Canva PNG. Drop the file in, set
+   --die-img to its url, and add the `has-img` class to each .ood-die — the
+   CSS metallic fallback below then steps aside. The PNG already carries its
+   own transparent padding + chrome rim, so `has-img` insets the face padding
+   to land the pills inside the rim (not over the bevel). */
+.ood-dice{display:flex;gap:10px;align-items:flex-start;--die-img:url("/assets/1die.png");}
+/* each cell stacks a two-line heading ABOVE its die */
+.ood-diecell{flex:1 1 0;min-width:0;display:flex;flex-direction:column;}
+/* heading now sits outside the die, on the silver body (one word per line) */
+.ood-die-h{margin:0 0 5px;font-family:Poppins,sans-serif;font-weight:700;font-size:.92rem;line-height:1.12;letter-spacing:.01em;color:#19007D;text-align:center;}
+.ood-die{width:100%;position:relative;border-radius:18px;padding:5px;
+  background:var(--die-img,none) center/100% 100% no-repeat,
+    linear-gradient(145deg,#F7F9FA 0%,#A6A7A7 47%,#CCCDCF 53%,#F0F4F5 100%);
+  box-shadow:0 1px 0 rgba(255,255,255,.85) inset,0 0 0 1px rgba(153,155,155,.55),0 10px 20px -10px rgba(6,2,28,.5);}
+.ood-die.has-img{aspect-ratio:1/1;box-shadow:none;border-radius:0;background:var(--die-img) center/contain no-repeat;}
+.ood-die-face{position:relative;height:100%;border-radius:14px;padding:13px 12px 15px;text-align:center;
+  background:linear-gradient(135deg,#F7F9FA 0%,#E8ECF4 38%,#DCE3E8 68%,#F0F4F5 100%);
+  box-shadow:0 1px 2px rgba(6,2,28,.20) inset,0 1px 0 rgba(255,255,255,.9) inset;}
+/* with the real art, the die holds ONLY pills now (heading moved out), so they
+   are distributed to fill the freed face height */
+.ood-die.has-img .ood-die-face{background:none;box-shadow:none;border-radius:0;padding:11%;display:flex;}
+.ood-die.has-img .ood-pills{flex:1;justify-content:space-evenly;gap:4px;}
+.ood-die.has-img .ood-pill{white-space:normal;padding:5px 9px;}
+.ood-pills{display:flex;flex-direction:column;align-items:center;gap:6px;}
 .ood-pillrow{display:flex;gap:5px;}
 .ood-pill{font-size:.55rem;font-weight:600;line-height:1.3;padding:3px 8px;border-radius:999px;white-space:nowrap;max-width:100%;}
-.ood-pill--sun{background:#FCEFBE;color:#0F031C;}
+/* white pills with neutral midnight-black text — references real dice (black
+   pips on white). Products + services share the look; the two dice + headings
+   already do the separating. Neutral ink (not the indigo #0F031C) so the text
+   doesn't read blue on white. */
+.ood-pill--sun,.ood-pill--indigo{background:#fff;color:#141414;box-shadow:0 0 0 1px rgba(150,155,162,.55),0 1px 2px rgba(6,2,28,.28);}
 .ood-pill--ruby{background:#FBE0D8;color:#0F031C;}
 .ood-pill--teal{background:#CDEFEA;color:#0F031C;}
-.ood-pill--indigo{background:#E7E0FA;color:#19007D;}
 @media (max-width:760px){.ood-grid{grid-template-columns:1fr;}.ood{padding:40px 18px 64px;}}
 @media (prefers-reduced-motion:reduce){.ood-key{transition:none;}}
